VITE_API_BASE_URL=http://localhost:8000
# Business/AI split deployment (recommended for service split).
# VITE_BUSINESS_API_BASE_URL=http://localhost:8000
# VITE_AI_API_BASE_URL=http://localhost:8001
# Optional: override file/preview/download host if it differs from the API origin.
# VITE_FILE_BASE_URL=http://localhost:8000
# Optional: override only business-side file/download host.
# VITE_BUSINESS_FILE_BASE_URL=http://localhost:8000
# Optional: override only AI-side file/preview/download host.
# VITE_AI_FILE_BASE_URL=http://localhost:8001
# Optional: override only the local Vite dev proxy target.
# VITE_DEV_API_PROXY_TARGET=http://localhost:8000

# ─── 基础环境 ───
APP_ENV=development

# ─── 数据库 (PostgreSQL) ───
DATABASE_URL=postgresql+asyncpg://postgres:123456@127.0.0.1:5432/ocr_db

# ─── 缓存 (Redis) ───
REDIS_URL=redis://127.0.0.1:6379/0

# ─── 消息队列 (RabbitMQ) ───
MQ_BROKER_URL=amqp://ocr_admin:ocr_password123@127.0.0.1:5672//
CELERY_BROKER_URL=amqp://ocr_admin:ocr_password123@127.0.0.1:5672//
MQ_PREFETCH_COUNT=1

# Spring Boot 侧 RabbitMQ 配置 (Java 控制面读取)
SPRING_RABBITMQ_HOST=127.0.0.1
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=ocr_admin
SPRING_RABBITMQ_PASSWORD=ocr_password123
SPRING_RABBITMQ_VHOST=/

# ─── 服务间通信 ───
CONTROL_PLANE_BASE_URL=http://127.0.0.1:8080
CONTROL_PLANE_VERIFY_TLS=false
OCR_CONTROL_PLANE_BASE_URL=http://127.0.0.1:8080
OCR_AI_BASE_URL=http://127.0.0.1:8001
OCR_INTERNAL_API_TOKEN=change-this-internal-token

# ─── 对象存储 (MinIO) ───
OCR_STORAGE_BACKEND=s3
OCR_STORAGE_ENDPOINT=http://127.0.0.1:9000
OCR_STORAGE_BUCKET=ocr-source
OCR_STORAGE_REGION=us-east-1
OCR_STORAGE_ACCESS_KEY=admin
OCR_STORAGE_SECRET_KEY=admin123456
OCR_STORAGE_KEY_PREFIX=uploads
OCR_STORAGE_PATH_STYLE=true

# ─── 认证 ───
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_SECRET=change-this-secret

# ─── 开发后台 (/dev/dashboard) ───
DEV_DASHBOARD_ENABLED=true
DEV_DASHBOARD_USERNAME=devadmin
DEV_DASHBOARD_PASSWORD=change-me-dev-dashboard
DEV_DASHBOARD_2FA_SECRET=JBSWY3DPEHPK3PXP
DEV_DASHBOARD_SESSION_SECRET=change-this-dev-dashboard-session-secret
DEV_DASHBOARD_COOKIE_NAME=ocr_dev_dashboard_session
DEV_DASHBOARD_COOKIE_SECURE=false
DEV_DASHBOARD_COOKIE_SAMESITE=lax
DEV_DASHBOARD_SESSION_TTL=28800
DEV_DASHBOARD_2FA_WINDOW_STEPS=1

# ─── 跨域 (CORS) ───
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── OCR 识别引擎 ───
OCR_USE_GPU=false
OCR_DEVICE=cpu
OCR_VL_BACKEND=baidu

# ─── LLM 智能提取 (MiniMax，OpenAI 兼容接口) ───
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_API_KEY=sk-cp-2pv7BaZEacsenaineyVhVO98qTGGgph7E3-Mc_QPyK9PU6ttygM-LHL9Pjmsm7PJLNtEmKTclFAIs8-mJDR_OvapTySNhs-FpDLKOxx4F-aLQ1OX1EEH2cE
LLM_MODEL=MiniMax-M2.7
VISION_LLM_BASE_URL=
VISION_LLM_API_KEY=
VISION_LLM_MODEL=

# 旧 MiniMax 配置 (向后兼容，优先级低于 LLM_*)
MINIMAX_ENABLED=true
MINIMAX_API_KEY=sk-cp-2pv7BaZEacsenaineyVhVO98qTGGgph7E3-Mc_QPyK9PU6ttygM-LHL9Pjmsm7PJLNtEmKTclFAIs8-mJDR_OvapTySNhs-FpDLKOxx4F-aLQ1OX1EEH2cE

# ─── 百度 AI Cloud (文档解析) ───
BAIDU_API_KEY=9Y5bjDkPRYKYOVuHeujAgS67
BAIDU_SECRET_KEY=Dakk7H7SBSPJKVmz15H3k8ipEj4Dr1k3

# ─── LangGraph / LangChain (可选) ───
LANGGRAPH_CHECKPOINTER_BACKEND=memory
LANGGRAPH_CHECKPOINTER_DSN=
LANGGRAPH_CHECKPOINTER_REDIS_URL=
LANGGRAPH_HITL_ENABLED=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ocr-web-compute
LANGCHAIN_TRACING_V2=false

# ─── 本地文件系统访问 ───
LOCAL_PATH_ROOTS=D:\Code\work\OCR\ocr\docker-data\minio\data\ocr-source\uploads,D:\Code\work\OCR\ocr\uploads-java,D:\Code\work\OCR\ocr\app\uploads,D:\Code\work\OCR\ocr\app

# ─── 缓存/数据目录 (Windows D 盘) ───
CACHE_DIR=D:\Code\work\OCR\ocr\app\.cache
UPLOAD_DIR=D:\Code\work\OCR\ocr\app\uploads
HF_HOME=D:\Code\work\OCR\ocr\app\.cache\huggingface
WORKER_TEMP_DIR=D:\Code\work\OCR\ocr\app\.cache\worker-temp
PADDLE_PDX_CACHE_HOME=D:\Code\work\OCR\ocr\app\.cache\paddlex

# Database
POSTGRES_PASSWORD=ocr123456
BACKEND_PORT=8000
FRONTEND_PORT=80
POSTGRES_PORT=5432
REDIS_PORT=6379
APP_ENV=production

# Runtime entrypoints
# Combined mode: `python app/main.py`
# Business-only mode: `python app/main_business.py`
# AI-only mode: `python app/main_ai.py`
BUSINESS_BACKEND_PORT=8000
AI_BACKEND_PORT=8001

# OCR runtime
OCR_USE_GPU=true
OCR_DEVICE=gpu:0
OCR_LANG=ch
OCR_VL_BACKEND=auto
OCR_LAYOUT_BACKEND=local
OCR_LAYOUT_API_URL=
OCR_LAYOUT_API_TOKEN=
OCR_LAYOUT_API_TIMEOUT_SECONDS=120
OCR_LAYOUT_API_USE_DOC_ORIENTATION_CLASSIFY=false
OCR_LAYOUT_API_USE_DOC_UNWARPING=false
OCR_LAYOUT_API_USE_CHART_RECOGNITION=false
ENABLE_HIERARCHICAL_AGENT=false
MAX_RETRIES=2
CONFIDENCE_THRESHOLD=0.85
HUMAN_REVIEW_MIN_CONFIDENCE=0.60
HUMAN_REVIEW_MAX_CONFIDENCE=0.85
VISION_ROUTE_COMPLEXITY_THRESHOLD=0.45

# Auth
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_SECRET=change-this-secret
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_TTL=28800

# Frontend access
# Local separated development defaults to Vite on :3000 and FastAPI on :8000.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# If frontend and backend are deployed on different sites and still need cookie auth,
# also set:
# AUTH_COOKIE_SAMESITE=none
# AUTH_COOKIE_SECURE=true

# ─── LLM Configuration (新配置，推荐使用) ───
# 支持所有 OpenAI 兼容 API: MiniMax / Ollama / vLLM / LocalAI
# 切换 Provider 只需改这里，无需改代码
# 测试环境推荐:
# APP_ENV=test
# OCR_VL_BACKEND=api
# OCR_LAYOUT_BACKEND=api
# OCR_LAYOUT_API_URL=https://your-layout-api/layout-parsing
# OCR_LAYOUT_API_TOKEN=your-layout-token
# LLM_BASE_URL=https://api.minimaxi.com/v1
# LLM_API_KEY=your-minimax-key
# LLM_MODEL=MiniMax-M2.7
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_API_KEY=
LLM_MODEL=MiniMax-M2.7
LLM_TIMEOUT_SECONDS=60
LLM_MAX_INPUT_CHARS=12000
VISION_LLM_BASE_URL=
VISION_LLM_API_KEY=
VISION_LLM_MODEL=
VISION_LLM_TIMEOUT_SECONDS=90
#
# Ollama 本地部署示例:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=
# LLM_MODEL=qwen2.5:14b
#
# vLLM 本地部署示例:
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=token-abc123
# LLM_MODEL=Qwen/Qwen2.5-14B-Instruct

# ─── MiniMax (旧配置，向后兼容，优先级低于 LLM_*) ───
# 旧链路仍会读取这些配置；若留空，将回退到上面的 LLM_* 配置。
MINIMAX_ENABLED=false
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TIMEOUT_SECONDS=60
MINIMAX_MAX_INPUT_CHARS=12000
MINIMAX_BATCH_CONCURRENCY=20

# Local filesystem access
# Only absolute paths under these roots may be scanned or processed by /scan-folder and /upload-from-path.
LOCAL_PATH_ROOTS=/app/uploads,/app/data

# Optional seed import
# INIT_ARCHIVE_EXCEL_PATH=/app/data/archive.xls
# INIT_ARCHIVE_BATCH_ID=init_import

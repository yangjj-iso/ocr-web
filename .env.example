# Database
POSTGRES_PASSWORD=123456
BACKEND_PORT=8080
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
APP_ENV=production

# Runtime entrypoints
# AI API mode: `python -m app.main_ai`
# Compute worker mode: `python -m app.main_worker`
# Celery mode: `celery -A app.infrastructure.queue.celery_app:celery_app worker -l info`
AI_BACKEND_PORT=8001

# MQ / control-plane contract
MQ_BROKER_URL=amqp://ocr_admin:ocr_password123@127.0.0.1:5672//
MQ_COMMAND_EXCHANGE=ocr.task.command.exchange
MQ_COMMAND_QUEUE=ocr.task.command.queue
MQ_COMMAND_ROUTING_KEY=ocr.task.submit.v1
MQ_COMMAND_DLX=ocr.task.command.dlx
MQ_COMMAND_DLQ=ocr.task.command.dlq
MQ_PREFETCH_COUNT=1
CELERY_BROKER_URL=amqp://ocr_admin:ocr_password123@127.0.0.1:5672//
CELERY_RESULT_BACKEND=
CELERY_TASK_EXCHANGE=ocr.compute.internal.exchange
CELERY_TASK_QUEUE=ocr.compute.internal.queue
CELERY_TASK_ROUTING_KEY=ocr.compute.execute.v1
CONTROL_PLANE_BASE_URL=http://127.0.0.1:8080
CONTROL_PLANE_INTERNAL_TOKEN=change-this-internal-token
CONTROL_PLANE_CALLBACK_TIMEOUT_SECONDS=15
CONTROL_PLANE_VERIFY_TLS=false
COMPUTE_WORKER_ID=py-compute-worker
WORKER_METRICS_ENABLED=true
WORKER_METRICS_HOST=0.0.0.0
WORKER_METRICS_PORT=9108
CALLBACK_INLINE_RESULT_MAX_BYTES=1048576
OCR_CONTROL_PLANE_BASE_URL=http://127.0.0.1:8080
LANGGRAPH_CHECKPOINTER_BACKEND=memory
LANGGRAPH_CHECKPOINTER_DSN=
LANGGRAPH_CHECKPOINTER_REDIS_URL=
LANGGRAPH_HITL_ENABLED=true
LANGGRAPH_HUMAN_REVIEW_INTERRUPT_THRESHOLD=0.70
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ocr-web-compute
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_TRACING_V2=false

# OCR runtime
OCR_USE_GPU=true
OCR_DEVICE=gpu:0
OCR_LANG=ch
OCR_VL_BACKEND=auto
OCR_LAYOUT_BACKEND=local
OCR_LAYOUT_API_URL=
OCR_LAYOUT_API_TOKEN=
OCR_LAYOUT_API_TIMEOUT_SECONDS=120
OCR_LAYOUT_API_USE_DOC_ORIENTATION_CLASSIFY=false
OCR_LAYOUT_API_USE_DOC_UNWARPING=false
OCR_LAYOUT_API_USE_CHART_RECOGNITION=false
ENABLE_HIERARCHICAL_AGENT=false
MAX_RETRIES=2
CONFIDENCE_THRESHOLD=0.85
HUMAN_REVIEW_MIN_CONFIDENCE=0.60
HUMAN_REVIEW_MAX_CONFIDENCE=0.85
OCR_PREPROCESS_COMPLEXITY_THRESHOLD=0.35
VISION_ROUTE_COMPLEXITY_THRESHOLD=0.45
BOUNDARY_SIMILARITY_THRESHOLD=12
BOUNDARY_GROUP_PDF_OUTPUT_DIRNAME=grouped_pdfs

# Auth
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_SECRET=change-this-secret
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_TTL=28800

# Frontend access
# Local separated development defaults to Vite on :3000, Java control plane on :8080, and Python AI API on :8001.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# If frontend and backend are deployed on different sites and still need cookie auth,
# also set:
# AUTH_COOKIE_SAMESITE=none
# AUTH_COOKIE_SECURE=true

# ─── LLM Configuration (新配置，推荐使用) ───
# 支持所有 OpenAI 兼容 API: MiniMax / Ollama / vLLM / LocalAI
# 切换 Provider 只需改这里，无需改代码
# 测试环境推荐:
# APP_ENV=test
# OCR_VL_BACKEND=api
# OCR_LAYOUT_BACKEND=api
# OCR_LAYOUT_API_URL=https://your-layout-api/layout-parsing
# OCR_LAYOUT_API_TOKEN=your-layout-token
# LLM_BASE_URL=https://api.minimaxi.com/v1
# LLM_API_KEY=your-minimax-key
# LLM_MODEL=MiniMax-M2.7
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_API_KEY=sk-cp-2pv7BaZEacsenaineyVhVO98qTGGgph7E3-Mc_QPyK9PU6ttygM-LHL9Pjmsm7PJLNtEmKTclFAIs8-mJDR_OvapTySNhs-FpDLKOxx4F-aLQ1OX1EEH2cE
LLM_MODEL=MiniMax-M2.7
LLM_TIMEOUT_SECONDS=60
LLM_MAX_INPUT_CHARS=12000
VISION_LLM_BASE_URL=https://api.minimaxi.com/v1
VISION_LLM_API_KEY=your-vision-llm-api-key
VISION_LLM_MODEL=MiniMax-M2.7
VISION_LLM_TIMEOUT_SECONDS=90
#
# Ollama 本地部署示例:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=
# LLM_MODEL=qwen2.5:14b
#
# vLLM 本地部署示例:
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=token-abc123
# LLM_MODEL=Qwen/Qwen2.5-14B-Instruct

# ─── MiniMax (旧配置，向后兼容，优先级低于 LLM_*) ───
# 旧链路仍会读取这些配置；若留空，将回退到上面的 LLM_* 配置。
MINIMAX_ENABLED=false
MINIMAX_API_KEY=sk-cp-2pv7BaZEacsenaineyVhVO98qTGGgph7E3-Mc_QPyK9PU6ttygM-LHL9Pjmsm7PJLNtEmKTclFAIs8-mJDR_OvapTySNhs-FpDLKOxx4F-aLQ1OX1EEH2cE
MINIMAX_API_HOST=https://api.minimaxi.com
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TIMEOUT_SECONDS=60
MINIMAX_MAX_INPUT_CHARS=12000
MINIMAX_BATCH_CONCURRENCY=20

# ─── D-drive path configuration (Windows) ───
# Explicitly set all cache/data directories to D drive to avoid falling back to C:\Users.
CACHE_DIR=D:\OCR_WEB\ocr\app\.cache
UPLOAD_DIR=D:\OCR_WEB\ocr\app\uploads
HF_HOME=D:\huggingface
WORKER_TEMP_DIR=D:\OCR_WEB\ocr\app\.cache\worker-temp
PADDLE_PDX_CACHE_HOME=D:\OCR_WEB\ocr\app\.cache\paddlex

# Local filesystem access
# Only absolute paths under these roots may be scanned or processed by /scan-folder and /upload-from-path.
LOCAL_PATH_ROOTS=D:\OCR_WEB\ocr\docker-data\minio\data\ocr-source\uploads,D:\OCR_WEB\ocr\uploads-java,D:\OCR_WEB\ocr\app\uploads,D:\OCR_WEB\ocr\app

# Java control-plane object storage (MinIO / OSS / S3-compatible)
OCR_STORAGE_BACKEND=s3
OCR_STORAGE_ENDPOINT=http://127.0.0.1:9000
OCR_STORAGE_BUCKET=ocr-source
OCR_STORAGE_REGION=us-east-1
OCR_STORAGE_ACCESS_KEY=admin
OCR_STORAGE_SECRET_KEY=admin123456
OCR_STORAGE_KEY_PREFIX=uploads
OCR_STORAGE_PATH_STYLE=true


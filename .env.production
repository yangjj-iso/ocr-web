# ─── Production profile ───
# Use this file through scripts\switch-env.ps1 prod, then replace all CHANGE_ME values.

APP_ENV=production

# ─── PostgreSQL ───
POSTGRES_DB=ocr_db
POSTGRES_USER=ocr_app
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ocr_app:CHANGE_ME_POSTGRES_PASSWORD@127.0.0.1:5432/ocr_db
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/ocr_db
SPRING_DATASOURCE_USERNAME=ocr_app
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# ─── Redis ───
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

# ─── RabbitMQ ───
RABBITMQ_DEFAULT_USER=ocr_app
RABBITMQ_DEFAULT_PASS=CHANGE_ME_RABBITMQ_PASSWORD
MQ_BROKER_URL=amqp://ocr_app:CHANGE_ME_RABBITMQ_PASSWORD@127.0.0.1:5672//
CELERY_BROKER_URL=amqp://ocr_app:CHANGE_ME_RABBITMQ_PASSWORD@127.0.0.1:5672//
MQ_COMMAND_EXCHANGE=ocr.task.command.exchange
MQ_COMMAND_QUEUE=ocr.task.command.queue
MQ_COMMAND_ROUTING_KEY=ocr.task.submit.v1
MQ_COMMAND_DLX=ocr.task.command.dlx
MQ_COMMAND_DLQ=ocr.task.command.dlq
MQ_PREFETCH_COUNT=2
SPRING_RABBITMQ_HOST=127.0.0.1
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=ocr_app
SPRING_RABBITMQ_PASSWORD=CHANGE_ME_RABBITMQ_PASSWORD
SPRING_RABBITMQ_VHOST=/

# ─── Service ports and internal URLs ───
BACKEND_PORT=8080
AI_BACKEND_PORT=8001
FRONTEND_PORT=3000
CONTROL_PLANE_BASE_URL=http://127.0.0.1:8080
OCR_CONTROL_PLANE_BASE_URL=http://127.0.0.1:8080
OCR_AI_BASE_URL=http://127.0.0.1:8001
CONTROL_PLANE_VERIFY_TLS=false
OCR_INTERNAL_API_TOKEN=CHANGE_ME_LONG_RANDOM_INTERNAL_TOKEN
CONTROL_PLANE_INTERNAL_TOKEN=CHANGE_ME_LONG_RANDOM_INTERNAL_TOKEN
CONTROL_PLANE_CALLBACK_TIMEOUT_SECONDS=30
CALLBACK_INLINE_RESULT_MAX_BYTES=1048576

# ─── Object storage: MinIO / S3-compatible ───
OCR_STORAGE_BACKEND=s3
OCR_STORAGE_ENDPOINT=http://127.0.0.1:9000
OCR_STORAGE_BUCKET=ocr-source
OCR_STORAGE_REGION=us-east-1
OCR_STORAGE_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
OCR_STORAGE_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
OCR_STORAGE_KEY_PREFIX=uploads
OCR_STORAGE_PATH_STYLE=true

# ─── Auth / public access ───
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
AUTH_SECRET=CHANGE_ME_LONG_RANDOM_AUTH_SECRET
AUTH_COOKIE_NAME=ocr_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none
AUTH_SESSION_TTL=28800
OCR_REQUIRE_USER_AUTH=true
OCR_RATE_LIMIT_ENABLED=true
CORS_ALLOW_ORIGINS=https://ocr.example.com
OCR_CORS_ALLOWED_ORIGIN_1=https://ocr.example.com
OCR_CORS_ALLOW_CREDENTIALS=true

# ─── OCR runtime ───
# Keep CPU by default. If you install CUDA PaddlePaddle, set OCR_USE_GPU=true and OCR_DEVICE=gpu:0.
OCR_USE_GPU=false
OCR_DEVICE=cpu
OCR_LANG=ch
OCR_VL_BACKEND=baidu
OCR_LAYOUT_BACKEND=local
OCR_LAYOUT_API_URL=
OCR_LAYOUT_API_TOKEN=
OCR_LAYOUT_API_TIMEOUT_SECONDS=120
ENABLE_HIERARCHICAL_AGENT=false
MAX_RETRIES=2
CONFIDENCE_THRESHOLD=0.85
HUMAN_REVIEW_MIN_CONFIDENCE=0.60
HUMAN_REVIEW_MAX_CONFIDENCE=0.85
BOUNDARY_SIMILARITY_THRESHOLD=12

# ─── LLM / MiniMax ───
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_API_KEY=CHANGE_ME_LLM_API_KEY
LLM_MODEL=MiniMax-M2.7
LLM_TIMEOUT_SECONDS=60
LLM_MAX_INPUT_CHARS=12000
MINIMAX_ENABLED=true
MINIMAX_API_KEY=CHANGE_ME_LLM_API_KEY
MINIMAX_API_HOST=https://api.minimaxi.com
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TIMEOUT_SECONDS=60
MINIMAX_MAX_INPUT_CHARS=12000
MINIMAX_BATCH_CONCURRENCY=20

# ─── Baidu document parsing ───
BAIDU_API_KEY=CHANGE_ME_BAIDU_API_KEY
BAIDU_SECRET_KEY=CHANGE_ME_BAIDU_SECRET_KEY

# ─── LangGraph / tracing ───
LANGGRAPH_CHECKPOINTER_BACKEND=memory
LANGGRAPH_CHECKPOINTER_DSN=
LANGGRAPH_CHECKPOINTER_REDIS_URL=
LANGGRAPH_HITL_ENABLED=true
LANGGRAPH_HUMAN_REVIEW_INTERRUPT_THRESHOLD=0.70
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ocr-web-compute
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_TRACING_V2=false

# ─── Worker metrics ───
COMPUTE_WORKER_ID=py-compute-worker-prod
WORKER_METRICS_ENABLED=true
WORKER_METRICS_HOST=0.0.0.0
WORKER_METRICS_PORT=9108

# ─── Local data/cache roots ───
CACHE_DIR=D:\Code\work\OCR\ocr\runtime\production\cache
UPLOAD_DIR=D:\Code\work\OCR\ocr\runtime\production\uploads
HF_HOME=D:\Code\work\OCR\ocr\runtime\production\cache\huggingface
WORKER_TEMP_DIR=D:\Code\work\OCR\ocr\runtime\production\cache\worker-temp
PADDLE_PDX_CACHE_HOME=D:\Code\work\OCR\ocr\runtime\production\cache\paddlex
LOCAL_PATH_ROOTS=D:\Code\work\OCR\ocr\runtime\production\uploads,D:\Code\work\OCR\ocr\uploads-java,D:\Code\work\OCR\ocr\app
